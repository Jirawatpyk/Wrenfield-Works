{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "remember@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "qodo-skills@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/guard-secrets.mjs\"",
            "statusMessage": "Checking for secret-file edits"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/format-changed.mjs\"",
            "statusMessage": "Formatting changed file",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
