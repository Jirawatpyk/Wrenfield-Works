# ==========================================================================
# Wrenfield Works — environment variable TEMPLATE (no real secrets here).
# Copy to `.env` and fill real values locally. NEVER commit `.env`.
# All personal data is stored/processed in the Asia-Pacific (Singapore) region.
# ==========================================================================

# --- Core ---
# PostgreSQL 16 connection (prod: managed, ap-southeast-1). Matches docker-compose.yml for local.
DATABASE_URI=postgres://wrenfield:wrenfield@localhost:5432/wrenfield
# Long, unguessable secret used by Payload to sign tokens. Generate: openssl rand -base64 32
PAYLOAD_SECRET=change-me-to-a-long-random-secret
# Public origin of the app (used for absolute URLs, CORS, email links).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Email (studio inquiry notifications; failure must never lose the stored inquiry, FR-029) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Wrenfield Works <hello@wrenfieldworks.com>"
# Where new-inquiry notifications are sent.
INQUIRY_NOTIFY_TO=hello@wrenfieldworks.com

# --- Spam protection (Cloudflare Turnstile — privacy-friendly, no cookies, FR-025) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=
# Per-IP inquiry rate limit.
INQUIRY_RATE_LIMIT_MAX=5
INQUIRY_RATE_LIMIT_WINDOW_MS=3600000

# --- Cookieless analytics (Plausible/Umami, self-hosted in-region; no consent banner, FR-011b) ---
NEXT_PUBLIC_ANALYTICS_DOMAIN=
NEXT_PUBLIC_ANALYTICS_SCRIPT_URL=

# --- Media object storage (S3-compatible, Singapore region, FR-030) ---
S3_ENDPOINT=
S3_REGION=ap-southeast-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Retention (PDPA: permanent deletion at 24 months, FR-027) ---
INQUIRY_RETENTION_MONTHS=24
